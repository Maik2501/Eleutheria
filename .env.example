# Eleutheria Flutter-App — Build-Time-Konfiguration.
#
# Diese Datei dient als Vorlage. Erzeuge eine echte .env-Datei daneben
# (kopiere und füll die Werte ein) — die echte .env ist gitignored.
#
# Build / Run:
#   flutter run --dart-define-from-file=.env
#
# Codemagic / CI: dieselben Variablen über Codemagic-Env-Vars setzen.

SUPABASE_URL=https://api.eleutheria.maikpickl.de
SUPABASE_ANON_KEY=PASTE_YOUR_ANON_KEY_HERE
